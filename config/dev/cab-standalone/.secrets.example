# Copy to .secrets and fill in your values — this file is gitignored
# Local Docker: set RL_AGENT_API_URL to the direct internal IP (e.g. http://192.168.x.x:5000/api/v1/recommendation)
# OVH/CI:       use the HTTPS URL and set the token
export RL_AGENT_API_URL=http://frontend:80/rl-api/recommendation
export RL_AGENT_API_TOKEN=
export VITE_COGNITIVE_TOKEN=
